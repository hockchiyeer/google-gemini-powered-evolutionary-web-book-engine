{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "cy:open": "cypress open",
    "test:local": "start-server-and-test dev http://localhost:3000 'cypress run --env ENVIRONMENT=DEV'",
    "test:qa": "cypress run --env ENVIRONMENT=QA",
    "test:prod": "cypress run --env ENVIRONMENT=PROD",
    "report:merge": "mochawesome-merge test-results/chromeReport/mochawesome-json/*.json > test-results/chromeReport/mochawesome.json",
    "report:generate": "marge test-results/chromeReport/mochawesome.json -f report -o test-results/chromeReport"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "firebase": "^12.11.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "puppeteer": "^24.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^17.2.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.3",
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cypress": "^15.13.1",
    "cypress-downloadfile": "^1.2.4",
    "cypress-iframe": "^1.0.1",
    "cypress-multi-reporters": "^2.0.5",
    "cypress-xpath": "^2.0.1",
    "esbuild": "^0.25.0",
    "mocha-junit-reporter": "^2.2.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "start-server-and-test": "^2.0.8",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
