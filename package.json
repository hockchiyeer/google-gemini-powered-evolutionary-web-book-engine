{
  "name": "evolutionary-web-book-engine",
  "private": true,
  "version": "0.0.0",
  "description": "Gemini-first evolutionary web-book engine with live search fallback and export tooling.",
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "vite --configLoader native --port=3000 --host=0.0.0.0",
    "dev:test": "vite --configLoader native --port=3001 --host=0.0.0.0",
    "start": "node ./scripts/start-preview.mjs",
    "package:aistudio": "node ./scripts/package-google-ai-studio.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "cy:open": "cypress open --config-file tests/cypress.config.cjs",
    "cy:run:local": "node tests/scripts/run-cypress-with-reports.cjs --environment DEV --baseUrl http://localhost:3001 --headed",
    "cy:run:qa": "node tests/scripts/run-cypress-with-reports.cjs --environment QA --headed",
    "cy:run:prod": "node tests/scripts/run-cypress-with-reports.cjs --environment PROD --headed",
    "test:local": "node tests/scripts/run-local-cypress.cjs",
    "test:unit": "node --experimental-strip-types tests/server/googleSearchFallback.test.ts",
    "test:qa": "npm run cy:run:qa",
    "test:prod": "npm run cy:run:prod",
    "report:merge": "mochawesome-merge test-results/chromeReport/mochawesome-json/*.json > test-results/chromeReport/mochawesome.json",
    "report:generate:mochawesome": "npm run report:merge && marge test-results/chromeReport/mochawesome.json -f report -o test-results/chromeReport",
    "report:generate:bdd": "node tests/scripts/generate-cucumber-report.cjs",
    "report:generate": "npm run report:generate:mochawesome && npm run report:generate:bdd"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "fflate": "^0.8.2",
    "firebase": "^12.11.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "puppeteer": "^24.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^17.2.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.3",
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cypress": "^15.13.1",
    "cypress-downloadfile": "^1.2.4",
    "cypress-iframe": "^1.0.1",
    "cypress-multi-reporters": "^2.0.5",
    "cypress-xpath": "^2.0.1",
    "esbuild": "^0.25.0",
    "mocha-junit-reporter": "^2.2.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "start-server-and-test": "^2.0.8",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
